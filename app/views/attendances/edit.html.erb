<% content_for :title, "Edit Attendance" %>

<div class="max-w-2xl mx-auto py-8">
  <section class="mb-8">
    <%= link_to employee_path(@employee, month: params[:month]), class: "inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors mb-4 group" do %>
      <div class="p-1 rounded-full bg-indigo-50 group-hover:bg-indigo-100 mr-2 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      </div>
      Back to Employee Profile
    <% end %>
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Edit Attendance Record</h1>
    <p class="mt-2 text-sm text-slate-500">Update the time tracking details for <%= @employee.name %>.</p>
  </section>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-5 pointer-events-none">
       <svg class="w-48 h-48 text-indigo-900" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-3.57-1.62-3.57-3.03 0-1.53 1.25-2.51 3.06-2.81V5h2.67v1.93c1.3.24 2.58 1.15 2.76 2.68h-1.96c-.19-1.04-.98-1.56-2.33-1.56-1.8 0-2.18.9-2.18 1.46 0 .86.51 1.44 2.8 1.98 2.38.56 3.44 1.62 3.44 3.06 0 1.5-.94 2.7-3.04 3.1z"/></svg>
    </div>
    <div class="relative z-10 max-w-sm mx-auto">
      <%= render "form", employee: @employee, attendance: @attendance, selected_month: @selected_month %>
    </div>
  </div>
</div>
