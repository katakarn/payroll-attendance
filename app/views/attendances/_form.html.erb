<%= form_with(model: [employee, attendance], data: { controller: "attendance-form" }, class: "space-y-5") do |form| %>
  <% if attendance.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50/80 p-4 shadow-sm relative overflow-hidden">
      <div class="absolute inset-y-0 left-0 w-1 bg-red-500"></div>
      <div class="flex items-start">
        <div class="flex-shrink-0 bg-red-100 rounded-full p-1 mr-3 mt-0.5">
          <svg class="h-4 w-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-red-800"><%= pluralize(attendance.errors.count, "error") %> prohibited this attendance from being saved:</h3>
          <ul class="mt-2 list-disc list-inside text-sm text-red-700">
            <% attendance.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%= hidden_field_tag :month, selected_month.strftime("%Y-%m") %>

  <div class="grid gap-5 sm:grid-cols-1">
    <div class="space-y-1">
      <%= form.label :work_date, class: "block text-sm font-semibold text-slate-700" %>
      <%= form.date_field :work_date, required: true, data: { attendance_form_target: "workDate", action: "change->attendance-form#syncDate input->attendance-form#syncDate" }, class: "w-full rounded-xl border border-slate-300 bg-slate-50/50 px-4 py-2.5 text-sm text-slate-900 shadow-sm transition-all outline-none focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div class="space-y-1">
      <%= form.label :check_in_at, "Check In Time", class: "block text-sm font-semibold text-slate-700" %>
      <%= form.datetime_local_field :check_in_at, value: attendance.check_in_at&.strftime("%Y-%m-%dT%H:%M"), required: true, data: { attendance_form_target: "checkIn" }, class: "w-full rounded-xl border border-slate-300 bg-slate-50/50 px-4 py-2.5 text-sm text-slate-900 shadow-sm transition-all outline-none focus:border-emerald-500 focus:bg-white focus:ring-2 focus:ring-emerald-500/20" %>
    </div>
    <div class="space-y-1">
      <%= form.label :check_out_at, "Check Out Time", class: "block text-sm font-semibold text-slate-700" %>
      <%= form.datetime_local_field :check_out_at, value: attendance.check_out_at&.strftime("%Y-%m-%dT%H:%M"), required: true, data: { attendance_form_target: "checkOut" }, class: "w-full rounded-xl border border-slate-300 bg-slate-50/50 px-4 py-2.5 text-sm text-slate-900 shadow-sm transition-all outline-none focus:border-amber-500 focus:bg-white focus:ring-2 focus:ring-amber-500/20" %>
    </div>
  </div>

  <div class="pt-2">
    <%= form.submit "Save Record", class: "w-full inline-flex justify-center items-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all cursor-pointer active:scale-95" %>
  </div>
<% end %>
