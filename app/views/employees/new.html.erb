<% content_for :title, "Add New Employee" %>

<div class="max-w-3xl mx-auto py-8">
  <section class="mb-8">
    <%= link_to employees_path, class: "inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors mb-4 group" do %>
      <div class="p-1 rounded-full bg-indigo-50 group-hover:bg-indigo-100 mr-2 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      </div>
      Back to Directory
    <% end %>
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Add New Employee</h1>
    <p class="mt-2 text-sm text-slate-500">Provide the basic information for the new team member.</p>
  </section>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-5 pointer-events-none">
       <svg class="w-48 h-48 text-indigo-900" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
    </div>
    <div class="relative z-10">
      <%= render "form", employee: @employee %>
    </div>
  </div>
</div>
