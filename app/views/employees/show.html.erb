<% content_for :title, "#{@employee.name} - Employee Profile" %>

<!-- Top Navigation / Actions -->
<section class="mb-6 flex flex-wrap items-center justify-between gap-4">
  <div class="flex items-center gap-4">
    <%= link_to employees_path, class: "p-2 rounded-full hover:bg-slate-200 text-slate-500 hover:text-slate-900 transition-colors bg-white shadow-sm ring-1 ring-slate-200", title: "Back to list" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
    <% end %>
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Employee Profile</h1>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to edit_employee_path(@employee), class: "inline-flex items-center rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition-colors active:scale-95" do %>
      <svg class="-ml-1 mr-2 h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" /></svg>
      Edit Profile
    <% end %>
  </div>
</section>

<!-- Profile Summary Card -->
<div class="mb-8 rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 overflow-hidden relative">
  <div class="absolute inset-x-0 top-0 h-24" style="background-color: rgba(2, 187, 241, 0.22);"></div>
  <div class="relative px-6 pt-12 pb-6 sm:px-8 sm:pt-16 sm:pb-8 flex flex-col sm:flex-row sm:items-end gap-6">
    <div class="h-24 w-24 rounded-full bg-white p-1 shadow-md ring-1 ring-slate-200 shrink-0 mx-auto sm:mx-0">
      <div class="h-full w-full rounded-full bg-indigo-100 flex items-center justify-center text-3xl font-bold text-indigo-700 uppercase">
        <%= @employee.name.blank? ? "?" : @employee.name[0..1] %>
      </div>
    </div>
    <div class="flex-1 text-center sm:text-left">
      <h2 class="text-3xl font-bold text-slate-900 tracking-tight"><%= @employee.name %></h2>
      <p class="mt-1 text-sm font-medium text-slate-500"><%= @employee.position %> • ID: #<%= @employee.id.to_s.rjust(4, '0') %></p>
    </div>
    <div class="bg-slate-50/80 backdrop-blur-sm rounded-xl p-4 ring-1 ring-slate-200 text-center sm:text-right shrink-0">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Base Salary</p>
      <p class="text-2xl font-bold text-slate-900"><%= number_to_currency(@employee.base_salary, unit: "฿", precision: 0) %></p>
    </div>
  </div>
</div>

<!-- Flex container for Controls and Metrics -->
<div class="mb-8 space-y-6">
  <!-- Month Picker -->
  <div class="w-full sm:w-auto rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 p-2 inline-block">
    <%= form_with url: employee_path(@employee), method: :get, class: "flex flex-col sm:flex-row sm:items-center gap-2" do |form| %>
      <div class="w-full relative flex items-center bg-slate-50 rounded-xl p-1 px-3 border border-slate-200 focus-within:ring-2 focus-within:ring-indigo-500 focus-within:border-indigo-500 transition-all">
         <svg class="w-5 h-5 text-indigo-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
         <%= form.month_field :month, value: @selected_month.strftime("%Y-%m"), class: "bg-transparent border-none text-sm font-semibold text-slate-700 focus:ring-0 p-1 w-full sm:w-36 outline-none cursor-pointer" %>
      </div>
      <%= form.submit "Apply Period", class: "w-full sm:w-auto rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors cursor-pointer active:scale-95" %>
    <% end %>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Stat Item -->
    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 relative overflow-hidden group hover:ring-blue-300 transition-all hover:shadow-md cursor-default">
      <div class="absolute top-0 right-0 p-4 opacity-[0.03] group-hover:scale-110 group-hover:opacity-10 transition-all duration-300"><svg class="w-24 h-24 text-blue-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.64-2.25 1.64-1.74 0-2.26-.95-2.32-1.81H7.84c.05 1.75 1.23 2.87 3.06 3.27V20h2.34v-1.63c1.55-.33 2.8-1.3 2.8-2.9 0-2.2-1.76-2.9-4.31-3.47z"/></svg></div>
      <dt class="text-sm font-medium text-slate-500 flex items-center gap-2 relative">
        <span class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center shadow-[inset_0_1px_1px_rgba(255,255,255,1)] ring-1 ring-blue-100"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
        Working Days
      </dt>
      <dd class="mt-4 flex items-baseline gap-2 relative">
        <span class="text-4xl font-bold tracking-tight text-slate-900"><%= @working_days %></span>
        <span class="text-sm font-medium text-slate-500">days</span>
      </dd>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 relative overflow-hidden group hover:ring-orange-300 transition-all hover:shadow-md cursor-default">
       <div class="absolute top-0 right-0 p-4 opacity-[0.03] group-hover:scale-110 group-hover:opacity-10 transition-all duration-300"><svg class="w-24 h-24 text-orange-500" fill="currentColor" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 16L12 15.45 7.77 18l1.12-4.81-3.73-3.23 4.92-.42L12 5l1.92 4.53 4.92.42-3.73 3.23L16.23 18z"/></svg></div>
      <dt class="text-sm font-medium text-slate-500 flex items-center gap-2 relative">
        <span class="w-8 h-8 rounded-lg bg-orange-50 text-orange-600 flex items-center justify-center shadow-[inset_0_1px_1px_rgba(255,255,255,1)] ring-1 ring-orange-100"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
        OT Hours
      </dt>
      <dd class="mt-4 flex items-baseline gap-2 relative">
        <span class="text-4xl font-bold tracking-tight text-slate-900"><%= @ot_hours %></span>
        <span class="text-sm font-medium text-slate-500">h</span>
      </dd>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 relative overflow-hidden group hover:ring-emerald-300 transition-all hover:shadow-md cursor-default">
       <div class="absolute top-0 right-0 p-4 opacity-[0.03] group-hover:scale-110 group-hover:opacity-10 transition-all duration-300"><svg class="w-24 h-24 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg></div>
      <dt class="text-sm font-medium text-slate-500 flex items-center gap-2 relative">
        <span class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center shadow-[inset_0_1px_1px_rgba(255,255,255,1)] ring-1 ring-emerald-100"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg></span>
        OT Pay
      </dt>
      <dd class="mt-4 relative">
        <span class="text-4xl font-bold tracking-tight text-slate-900"><%= number_to_currency(@ot_pay, unit: "฿", precision: 2) %></span>
      </dd>
    </div>

    <!-- Secondary Stats row -->
    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 relative overflow-hidden group hover:ring-indigo-300 transition-all hover:shadow-md cursor-default">
      <dt class="text-sm font-medium text-slate-500">Gross Pay <span>(This Month)</span></dt>
      <dd class="mt-3 text-3xl font-bold tracking-tight text-slate-900"><%= number_to_currency(@employee.gross_pay(@selected_month), unit: "฿", precision: 2) %></dd>
    </div>
    
    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 relative overflow-hidden group hover:ring-red-300 transition-all hover:shadow-md cursor-default">
      <dt class="text-sm font-medium text-slate-500">Tax Deductions</dt>
      <dd class="mt-3 text-3xl font-bold tracking-tight text-red-600">-<%= number_to_currency(@tax, unit: "฿", precision: 2) %></dd>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-indigo-600 to-indigo-800 p-6 shadow-lg ring-1 ring-indigo-700 relative overflow-hidden group hover:ring-indigo-400 transition-all transform hover:-translate-y-1 hover:shadow-indigo-500/30 cursor-default">
      <div class="absolute -right-6 -top-6 bg-white opacity-5 w-24 h-24 rounded-full blur-xl group-hover:scale-150 transition-transform duration-700"></div>
      <dt class="relative text-sm font-medium text-indigo-100 flex justify-between items-center">
        Net Pay Received
        <svg class="w-5 h-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      </dt>
      <dd class="relative mt-3 text-4xl font-bold tracking-tight text-white"><%= number_to_currency(@net_pay, unit: "฿", precision: 2) %></dd>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
  <!-- Add Attendance -->
  <div class="xl:col-span-1">
    <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sticky top-24">
      <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2 mb-6 tracking-tight">
        <span class="p-1.5 rounded-lg bg-indigo-50 text-indigo-600"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg></span>
        Log Attendance
      </h2>
      <%= render "attendances/form", employee: @employee, attendance: @attendance, selected_month: @selected_month %>
    </div>
  </div>

  <!-- Attendance Table -->
  <div class="xl:col-span-2">
    <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 overflow-hidden">
      <div class="p-6 border-b border-slate-200 flex items-center justify-between bg-slate-50/50">
         <h2 class="text-lg font-bold text-slate-900 tracking-tight">Attendance Records</h2>
         <span class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-600/10">
            <%= @attendance_records.count %> records
         </span>
      </div>

      <% if @attendance_records.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th scope="col" class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Date</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Time</th>
                <th scope="col" class="px-3 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wide">Summary</th>
                <th scope="col" class="relative py-3 pl-3 pr-6"><span class="sr-only">Actions</span></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
              <% @attendance_records.each do |attendance| %>
                <tr class="hover:bg-slate-50/70 transition-colors group">
                  <td class="whitespace-nowrap py-4 pl-6 pr-3 text-sm font-medium text-slate-900">
                    <div class="flex items-center gap-3">
                      <div class="flex flex-col text-center">
                        <span class="text-xs font-semibold text-slate-500 uppercase leading-none"><%= Date.parse(attendance.work_date.to_s).strftime("%a") %></span>
                        <span class="text-lg font-bold text-slate-900 leading-none mt-1"><%= Date.parse(attendance.work_date.to_s).strftime("%d") %></span>
                      </div>
                      <div class="text-slate-500 text-sm"><%= Date.parse(attendance.work_date.to_s).strftime("%b %Y") %></div>
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500">
                    <div class="flex items-center gap-2">
                      <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-1.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20" title="Check-in"><svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg><%= attendance.check_in_at.strftime("%H:%M") %></span>
                      <svg class="w-3 h-3 text-slate-300 mx-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                      <span class="inline-flex items-center rounded-md bg-amber-50 px-2 py-1.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20" title="Check-out"><%= attendance.check_out_at.strftime("%H:%M") %><svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg></span>
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-right flex-col justify-center gap-1">
                    <div class="text-slate-900 font-semibold text-base"><%= attendance.worked_hours %> <span class="text-slate-500 font-normal text-xs">hrs</span></div>
                    <% if attendance.ot_hours > 0 %>
                      <div class="inline-flex items-center mt-1 text-orange-600 font-bold text-xs bg-orange-50 px-2 py-0.5 rounded border border-orange-100">+<%= attendance.ot_hours %> OT</div>
                    <% end %>
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-6 text-right text-sm font-medium">
                    <div class="flex items-center justify-end gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 focus-within:opacity-100 transition-opacity">
                      <%= link_to edit_employee_attendance_path(@employee, attendance, month: @selected_month.strftime("%Y-%m")), class: "text-slate-600 hover:text-slate-900 bg-slate-100 hover:bg-slate-200 p-2 rounded-lg transition-colors focus:ring-2 focus:ring-slate-500 focus:outline-none", title: "Edit" do %>
                         <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" /></svg>
                      <% end %>
                      <%= button_to employee_attendance_path(@employee, attendance, month: @selected_month.strftime("%Y-%m")), method: :delete, class: "text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors focus:ring-2 focus:ring-red-500 focus:outline-none", form: { class: "inline-block" }, data: { turbo_confirm: "Delete this record?" }, title: "Delete" do %>
                         <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-16 text-center text-slate-500 flex flex-col items-center justify-center">
           <div class="bg-slate-100 p-4 rounded-full mb-4">
             <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
           </div>
           <h3 class="text-sm font-semibold text-slate-900">No attendance data</h3>
           <p class="mt-1 text-sm text-slate-500 max-w-sm">No attendance records have been logged for this period. Use the form to record time.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
