<% content_for :title, "Editing #{@employee.name}" %>

<div class="max-w-3xl mx-auto py-8">
  <section class="mb-8 flex flex-col sm:flex-row sm:items-end justify-between gap-4">
    <div>
      <%= link_to employee_path(@employee), class: "inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors mb-4 group" do %>
        <div class="p-1 rounded-full bg-indigo-50 group-hover:bg-indigo-100 mr-2 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        </div>
        Back to Profile
      <% end %>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Edit Employee</h1>
      <p class="mt-2 text-sm text-slate-500">Update the details for <%= @employee.name %>.</p>
    </div>
  </section>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-5 pointer-events-none">
       <svg class="w-48 h-48 text-indigo-900" fill="currentColor" viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
    </div>
    <div class="relative z-10">
      <%= render "form", employee: @employee %>
    </div>
  </div>
</div>
